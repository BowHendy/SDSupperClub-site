# Web3Forms — invitation request form (optional if you use Netlify Forms instead)
NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key
# Optional: override Web3Forms free hCaptcha site key.
# Default in code: 50b2fe65-b00b-4b9e-ad62-3ba471098be2
# NEXT_PUBLIC_WEB3FORMS_HCAPTCHA_SITEKEY=50b2fe65-b00b-4b9e-ad62-3ba471098be2

# Netlify Identity — only needed when the app is NOT served from your Netlify site
# (e.g. `next dev` on localhost). Point at your site’s Identity API:
# https://YOUR-SITE.netlify.app/.netlify/identity
# With `npx netlify dev`, leave unset so the widget uses the same origin.
# NEXT_PUBLIC_NETLIFY_IDENTITY_URL=

# --- Local Netlify DB (optional) ---
# In production, Netlify sets NETLIFY_DATABASE_URL when Netlify DB is linked.
# Paste a connection string from Neon (Netlify UI → Extensions → Neon) only here — never commit.
# If this URL was ever exposed, rotate the DB password in Neon and update Netlify + this file locally.
# npm run db:verify
# npm run db:apply-schema   (runs netlify/db/schema.sql once)
# Optional: run netlify/db/migration_content.sql if you created the DB before site_content / new meal columns existed.
# Optional: run netlify/db/seed-content.sql for default past menus + marketing JSON (key `site`).
# NETLIFY_DATABASE_URL=

# --- Netlify environment (set in Netlify UI only: Site → Environment variables) ---
# Never commit production secrets. Do not use NEXT_PUBLIC_ for these.
#
# Host-request notifications (Resend) — both required for email to send:
# RESEND_API_KEY=re_xxxx
# ADMIN_NOTIFICATION_EMAIL=your-admin@example.com
# RESEND_FROM_EMAIL=SDSupperClub <notifications@your-verified-domain.com>
#
# Optional: protect notify-waitlist stub
# ADMIN_NOTIFY_SECRET=
